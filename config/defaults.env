# cli-boot-kit shared defaults. Shell-safe key=value, sourced by modules.
# Override per host by editing this file before running the bootstrap.

# Login shell to set for the target user.
DEFAULT_SHELL=zsh

# IANA timezone applied by the bootstrap. Empty disables timezone management.
TIMEZONE=America/Los_Angeles

# chezmoi source repo passed to `chezmoi init <repo> --apply`.
CHEZMOI_REPO=l1ttleflyyy

# Trusted Tailscale CGNAT range, used by fail2ban ignoreip. This is the generic
# tailnet range, not a host-specific subnet.
TRUSTED_TAILNET_CIDR=100.64.0.0/10

# Developer CLIs installed via their official installers into the user's home.
INSTALL_CLAUDE=yes
INSTALL_CODEX=yes

# fail2ban ssh brute-force protection. Defaults on (safe for internet-facing
# hosts); set to `no` in a host profile for boxes on a trusted LAN with no
# inbound exposure. bootstrap skips the module when this is not `yes`.
INSTALL_FAIL2BAN=yes
