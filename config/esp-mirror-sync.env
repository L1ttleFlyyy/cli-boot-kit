# Managed by cli-boot-kit/scripts/modules/esp-mirror-sync.sh
#
# This host intentionally keeps only the primary ESP registered in UEFI NVRAM.
# The mirror ESP is a cold copy for manual recovery, not an automatic fallback
# boot path.

PRIMARY_ESP=/boot/efi
PRIMARY_ESP_UUID=A861-ECC8
MIRROR_ESP_UUID=A79D-4E05
MIRROR_MOUNT=/run/esp-mirror-sync/esp2
MOUNT_OPTIONS=umask=0077,shortname=winnt
