# cli-boot-kit profile: beelink
# Target: beelink — Fedora 44 Server, x86_64.
# Host-specific profile for an already-customized Fedora machine. Keep
# profiles/fedora-gen.env as the generic Fedora baseline; record overrides here
# when beelink differs from a fresh Fedora install.

# Identity
TIMEZONE=America/New_York

# SSH
SSH_PORT=60022

# Login shell for the target user.
DEFAULT_SHELL=zsh

# chezmoi source repo passed to `chezmoi init <repo> --apply`.
CHEZMOI_REPO=l1ttleflyyy

# Trusted Tailscale CGNAT range used by fail2ban ignoreip (generic, not a subnet).
TRUSTED_TAILNET_CIDR=100.64.0.0/10

# Developer CLIs (official installers into the user's home).
INSTALL_CLAUDE=yes
INSTALL_CODEX=yes

# Optional modules (declarative toggles; bootstrap obeys these, no prompts).
INSTALL_TAILSCALE=yes

# beelink has policy-routed public traffic through Cloudflare WARP, so automatic
# default-route detection sees warp0. For Tailscale network optimization, use
# the physical LAN interface instead.
TAILSCALE_NETDEV=enp2s0
ADVERTISE_EXIT_NODE=no

INSTALL_PODMAN_QUADLET=yes
APPLY_ROUTER_SYSCTL=yes
