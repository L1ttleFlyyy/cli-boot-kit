# cli-boot-kit profile: fedora-gen
# Target: beelink — Fedora 44 Server, x86_64.
# Shell-safe key=value. This profile is the single source of truth for the host;
# config/defaults.env + config/ssh.env only provide fallback baselines beneath it.
# NOTE: values below are reasonable initial guesses; verify on the host (TODO1).

# Identity
TIMEZONE=America/New_York

# SSH
SSH_PORT=60022

# Login shell for the target user.
DEFAULT_SHELL=zsh

# chezmoi source repo passed to `chezmoi init <repo> --apply`.
CHEZMOI_REPO=l1ttleflyyy

# Trusted Tailscale CGNAT range used by fail2ban ignoreip (generic, not a subnet).
TRUSTED_TAILNET_CIDR=100.64.0.0/10

# Developer CLIs (official installers into the user's home).
INSTALL_CLAUDE=yes
INSTALL_CODEX=yes

# Optional modules (declarative toggles; bootstrap obeys these, no prompts).
# INSTALL_TAILSCALE installs tailscale + ethtool + IP-forwarding sysctl + the
# UDP GRO optimization service. Registration and --advertise-exit-node stay a
# manual `tailscale up`.
INSTALL_TAILSCALE=yes
TAILSCALE_NETDEV=          # empty => auto-detect; override if the host has policy routing
INSTALL_PODMAN_QUADLET=yes
APPLY_ROUTER_SYSCTL=yes
